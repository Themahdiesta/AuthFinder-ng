# ── HTTP Basic Auth ────────────────────────────────────────────────────────────
test_http() {
    local ip="$1" port="$2" user="$3" cred="$4" is_hash="$5" proto="${6:-http}"

    if [[ "$is_hash" == "1" ]]; then
        lprint "  ${DIM}[HTTP:${port}] Skipped — HTTP basic auth does not support hashes${NC}"
        return 1
    fi

    local label="${proto^^}:${port}"
    lprint "\n  ${STEP} ${BOLD}${label}${NC}"

    local url="${proto}://${ip}:${port}/"
    local curl_cmd="curl -sk -o /dev/null -w '%{http_code}' -u '${user}:${cred}' '${url}'"
    p_cmd_display "$curl_cmd"
    local status; status=$(eval "$curl_cmd" 2>/dev/null) || status="000"
    LAST_OUT="HTTP Status: ${status}"
    lprint "    ${DIM}│${NC} HTTP Status: ${status}"

    if [[ "$status" == "200" || "$status" == "301" || "$status" == "302" ]]; then
        p_hit "${label} — ${user}@${ip} — HTTP AUTH VALID (${status})"
        record_hit "$ip" "http" "$port" "$user" "$cred" "$is_hash" "no"
        return 0
    elif [[ "$status" == "401" || "$status" == "403" ]]; then
        lprint "  ${FAIL} ${label} — Auth rejected (${status})"
        return 1
    fi

    # Try hydra if available
    if tool_exists hydra; then
        _run "hydra -l '${user}' -p '${cred}' -s ${port} ${ip} http-get / -t 1 2>/dev/null" "$TIMEOUT" || true
        if echo "$LAST_OUT" | grep -qi "login.*password"; then
            p_hit "${label} — ${user}@${ip} — HTTP AUTH (hydra)"
            record_hit "$ip" "http" "$port" "$user" "$cred" "$is_hash" "no"
            return 0
        fi
    fi

    return 1
}

# ── Null / Anonymous Auth Check ────────────────────────────────────────────────
check_null_auth() {
    local ip="$1"
    p_hdr "Null / Anonymous Auth Check — ${ip}"

    # SMB null session
    if echo "${DISCOVERED_SERVICES:-}" | grep -q "smb:"; then
        local smb_port; smb_port=$(echo "${DISCOVERED_SERVICES:-smb:445:}" | grep -oP "smb:\K[0-9]+" | head -1)
        smb_port="${smb_port:-445}"
        p_info "Testing SMB null session..."
        _run "${NXC} smb ${ip} --port ${smb_port} -u '' -p ''" "$TIMEOUT" || true
        echo "$LAST_OUT" | grep -q "\[+\]" && p_warn "SMB null session allowed — unauthenticated access!"
        _run "${NXC} smb ${ip} --port ${smb_port} -u 'guest' -p ''" "$TIMEOUT" || true
        echo "$LAST_OUT" | grep -q "\[+\]" && p_warn "SMB guest access allowed!"
    fi

    # LDAP anonymous bind
    if echo "${DISCOVERED_SERVICES:-}" | grep -q "ldap:"; then
        local ldap_port; ldap_port=$(echo "${DISCOVERED_SERVICES:-ldap:389:}" | grep -oP "ldap:\K[0-9]+" | head -1)
        ldap_port="${ldap_port:-389}"
        p_info "Testing LDAP anonymous bind..."
        if tool_exists ldapsearch; then
            _run "ldapsearch -x -H ldap://${ip}:${ldap_port} -b '' -s base namingContexts 2>/dev/null" "$TIMEOUT" || true
            echo "$LAST_OUT" | grep -qi "namingContexts\|dn:" && p_warn "LDAP anonymous bind allowed!"
        fi
    fi

    # FTP anonymous
    if echo "${DISCOVERED_SERVICES:-}" | grep -q "ftp:"; then
        local ftp_port; ftp_port=$(echo "${DISCOVERED_SERVICES:-ftp:21:}" | grep -oP "ftp:\K[0-9]+" | head -1)
        ftp_port="${ftp_port:-21}"
        p_info "Testing FTP anonymous login..."
        _run "${NXC} ftp ${ip} --port ${ftp_port} -u 'anonymous' -p 'anonymous@'" "$TIMEOUT" || true
        echo "$LAST_OUT" | grep -q "\[+\]" && p_warn "FTP anonymous login allowed!"
    fi
}

