    lprint ""
    lprint "${BOLD}${LC}╔══ POST-EXPLOITATION — ${proto^^}:${port} — ${user}@${ip} ══╗${NC}"

    # Interactive shell
    lprint "${BOLD}  [1] Interactive Shell${NC}"
    case "$proto" in
        smb|wmi)
            p_cmd_display "$(imp wmiexec) ${auth_imp}"
            p_cmd_display "$(imp smbexec) ${auth_imp}"
