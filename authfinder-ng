# NEXT STEPS (context-aware post-exploitation guide)
# ═══════════════════════════════════════════════════════════════════════════════
show_next_steps() {
    local proto="$1" ip="$2" port="$3" user="$4" cred="$5" is_hash="$6"
    local h="${cred#:}"; h="${h//\'/}"
    local dp="${DOMAIN:+${DOMAIN}/}"
    local nxc_d=""; [[ -n "$DOMAIN" ]] && nxc_d=" -d '${DOMAIN}'"
    $LOCAL_AUTH && nxc_d=" --local-auth"

