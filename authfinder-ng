#!/usr/bin/env bash
# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  authfinder-ng v4.0 — Multi-Protocol Credential Testing & Access Engine     ║
# ║  Protocols : SMB · WinRM · WMI · RDP · SSH · FTP · MSSQL · LDAP · HTTP     ║
# ║  Features  : Smart discovery · Service fingerprinting · Scan cache          ║
# ║              Non-standard ports · Spray engine · Lockout protection         ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

readonly VERSION="4.0"
readonly CACHE_DIR="${HOME}/.cache/authfinder-ng"
readonly CACHE_TTL=86400   # 24 h

# ── Colors ─────────────────────────────────────────────────────────────────────
R=$'\033[0;31m'   LR=$'\033[1;31m'  G=$'\033[0;32m'  LG=$'\033[1;32m'
Y=$'\033[1;33m'   B=$'\033[0;34m'   C=$'\033[0;36m'  LC=$'\033[1;36m'
M=$'\033[0;35m'   W=$'\033[1;37m'   OR=$'\033[38;5;208m'
DIM=$'\033[2m'    BOLD=$'\033[1m'   NC=$'\033[0m'

OK="${LG}[+]${NC}"       FAIL="${LR}[-]${NC}"     WARN="${Y}[!]${NC}"
INFO="${LC}[*]${NC}"     CMD_LBL="${OR}[CMD]${NC}" AUTH="${Y}[AUTH]${NC}"
HIT="${LG}${BOLD}[HIT]${NC}" SEC="${LR}${BOLD}[!!]${NC}" STEP="${M}[→]${NC}"

# ── Tool binaries (resolved at runtime) ────────────────────────────────────────
NXC="nxc"
IMP="impacket-"
RDP_BIN="xfreerdp3"
RDP_CERT="/cert:ignore"
PROXYCHAINS=""   # "proxychains -q" when --proxy is set

# ── Runtime globals ────────────────────────────────────────────────────────────
TARGET=""
USERS=()
PASSES=()
CRED_IS_HASH=0
DOMAIN=""
EXEC_CMD="whoami /all"
SELECTED_TOOLS=()
ALL_TOOLS=(smb winrm wmi rdp mssql ssh ftp ldap)
WIN_TOOLS=(smb winrm wmi rdp mssql)
LINUX_TOOLS=(ssh ftp)

SKIP_SCAN=false
RESCAN=false
RUN_ALL=false
SHOW_STEPS=true
VERBOSE=false
THREADS=5
TIMEOUT=22
WINRM_TO=35
RDP_TO=40
DELAY=0
LOCKOUT_THRESH=3
REPORT_FILE=""
LOCAL_AUTH=false
LINUX_MODE=false
ONLY_CHECK=false
ONLY_INSTALL=false
SAFE_SPRAY=true
ADD_TO_HOSTS=false
PROXY=""

TMP_DIR=""
HITS_FILE=""
AUTH_FILE=""
LOCK_FILE=""
FAIL_FILE=""
CMD_LOG=""

# ═══════════════════════════════════════════════════════════════════════════════
# PRINT HELPERS
# ═══════════════════════════════════════════════════════════════════════════════
lprint() {
    if [[ -n "${LOCK_FILE:-}" && -f "${LOCK_FILE:-}" ]]; then
        ( flock -x 200; echo -e "$*" ) 200>"$LOCK_FILE"
    else
        echo -e "$*"
    fi
}

p_ok()   { lprint "${OK} $*"; }
p_fail() { lprint "${FAIL} $*"; }
p_warn() { lprint "${WARN} ${Y}$*${NC}"; }
p_info() { lprint "${INFO} $*"; }
p_step() { lprint "\n${STEP} ${BOLD}$*${NC}"; }
p_hit()  { lprint "${HIT} ${LG}${BOLD}$*${NC}"; }
p_sec()  { lprint "${SEC} ${LR}${BOLD}$*${NC}"; }
p_sep()  { lprint "${DIM}────────────────────────────────────────────────────────────${NC}"; }
p_hdr()  { lprint "\n${BOLD}${LC}▶ $*${NC}"; lprint "${DIM}────────────────────────────────────────────────────────────${NC}"; }
p_dbg()  { $VERBOSE && lprint "    ${DIM}[DBG] $*${NC}" || true; }
p_tip()  { lprint "    ${C}[TIP]${NC} ${DIM}$*${NC}"; }
p_cmd_display() {
    lprint "    ${CMD_LBL} ${OR}$*${NC}"
    # Log command
    [[ -n "${CMD_LOG:-}" ]] && echo "$*" >> "$CMD_LOG" 2>/dev/null || true
}

show_output() {
    local out="$1"
    [[ -z "$out" ]] && return
    lprint "${DIM}    ┌────────────────────────────────────────────────────────────${NC}"
    while IFS= read -r line; do
        line="${line//\[+\]/$'\033[1;32m[+]\033[0m'}"
        line="${line//\[-\]/$'\033[1;31m[-]\033[0m'}"
        line="${line//Pwn3d!/$'\033[1;31mPwn3d!\033[0m'}"
        line="${line//SUCCEED/$'\033[1;32mSUCCEED\033[0m'}"
        line="${line//SUCCESS/$'\033[1;32mSUCCESS\033[0m'}"
        line="${line//FAILED/$'\033[1;31mFAILED\033[0m'}"
        lprint "    ${DIM}│${NC} ${line}"
    done <<< "$out"
    lprint "${DIM}    └────────────────────────────────────────────────────────────${NC}"
}

