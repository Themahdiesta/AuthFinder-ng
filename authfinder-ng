# ═══════════════════════════════════════════════════════════════════════════════
# IP RANGE PARSER
# ═══════════════════════════════════════════════════════════════════════════════
parse_ip_range() {
    local range="$1"

    # File of IPs
    if [[ -f "$range" ]]; then
        while IFS= read -r line; do
            line="${line%%#*}"; line="${line// /}"
            [[ -z "$line" ]] && continue
            parse_ip_range "$line"
        done < "$range"
        return
    fi

    # CIDR
    if [[ "$range" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+/[0-9]+$ ]]; then
        python3 -c "import ipaddress
for ip in ipaddress.ip_network('${range}',strict=False).hosts(): print(ip)" 2>/dev/null
        return
    fi

    # Dash range in last octet: 10.10.10.1-50
    if [[ "$range" =~ ^([0-9]+\.[0-9]+\.[0-9]+\.)([0-9]+)-([0-9]+)$ ]]; then
        local prefix="${BASH_REMATCH[1]}" start="${BASH_REMATCH[2]}" end="${BASH_REMATCH[3]}"
        for (( i=start; i<=end; i++ )); do echo "${prefix}${i}"; done
        return
    fi

    # Single IP
    echo "$range"
}

